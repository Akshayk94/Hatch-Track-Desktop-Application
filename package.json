{
  "name": "hatch-track-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist:mac-arm": "electron-builder --mac dmg --arm64"
  },
  "build": {
    "appId": "com.hatchtrack.app",
    "productName": "HatchTrackAdmin",
    "directories": {
      "output": "dist-desktop"
    },
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "frontend/images/icon.png"
    },
    "mac": {
      "target": "dmg"
    },
    "files": [
      "main.js",
      "frontend/**/*",
      "backend/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3"
  }
}
